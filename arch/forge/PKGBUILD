# Maintainer: Aman Adlakha <amanady125@gmail.com>
pkgname=ethos-forge
pkgver=0.3.0
pkgrel=1
pkgdesc="The Ethos Package Manager"
arch=('x86_64' 'aarch64')
url="https://github.com/AmanCode22/forge"
license=('Apache-2.0')

provides=('forge')
conflicts=('forge')

depends=('ethos-lang' 'python' 'python-zstandard' 'gcc' 'patchelf')
makedepends=('python-pip' 'python-setuptools' 'python-wheel')

options=('!lto' '!strip')

source=("forge-v${pkgver}.tar.gz")
sha256sums=('SKIP')

build() {
  cd "forge-${pkgver}"
  python3 -m pip install --user --break-system-packages --no-build-isolation --no-deps --no-index --find-links=vendor nuitka
  unset LDFLAGS
  python3 -m nuitka --assume-yes-for-downloads --jobs=1 --lto=no --low-memory --onefile main.py --output-filename=forge
}

package() {
  cd "forge-${pkgver}"
  install -Dm755 forge "${pkgdir}/usr/bin/forge"
}
